#!/usr/bin/env bash
# LCW setup — register skill with a project (multi-host)
set -e

LCW_DIR="$(cd "$(dirname "$0")" && pwd -P)"
SKILL_SRC="$LCW_DIR/skills/lcw"

# ─── Parse flags ──────────────────────────────────────────────

PROJECT=""
HOSTS=""
while [ $# -gt 0 ]; do
  case "$1" in
    --host)   HOSTS="$HOSTS $2"; shift 2 ;;
    --host=*) HOSTS="$HOSTS ${1#--host=}"; shift ;;
    -h|--help)
      cat <<'EOF'
Usage: ~/.lcw/setup [<project>] [--host <host>...]

Install LCW skill into a project by creating symlinks.
Only project-level installation is supported — no global install.

Arguments:
  <project>          Target project directory (default: current directory)

Options:
  --host <host>      Host tool: claude, codex, opencode, windsurf
                     (default: claude; repeatable)

Examples:
  ~/.lcw/setup                                # current dir, Claude Code
  ~/.lcw/setup ~/work/my-wiki                 # specific project
  ~/.lcw/setup --host codex --host opencode   # multiple hosts
  ~/.lcw/setup ~/work/my-wiki --host codex    # both
EOF
      exit 0
      ;;
    *)
      if [ -z "$PROJECT" ]; then
        PROJECT="$1"
      fi
      shift
      ;;
  esac
done

[ -z "$PROJECT" ] && PROJECT="."
[ -z "$HOSTS" ] && HOSTS="claude"

# ─── Resolve project path ────────────────────────────────────

PROJECT="$(cd "$PROJECT" && pwd -P)"

# ─── Create symlinks ─────────────────────────────────────────

link_skill() {
  local dest="$1"
  mkdir -p "$dest"

  if [ -L "$dest/lcw" ]; then
    rm "$dest/lcw"
  elif [ -e "$dest/lcw" ]; then
    echo "  skip: $dest/lcw exists and is not a symlink" >&2
    return
  fi

  ln -s "$SKILL_SRC" "$dest/lcw"
  echo "  $dest/lcw -> $SKILL_SRC"
}

host_to_path() {
  case "$1" in
    claude)   echo ".claude/skills" ;;
    codex)    echo ".codex/skills" ;;
    opencode) echo ".opencode/skills" ;;
    windsurf) echo ".windsurf/skills" ;;
    *)        echo "" ;;
  esac
}

echo "Setting up LCW in $PROJECT"

for HOST in $HOSTS; do
  SKILL_DIR="$(host_to_path "$HOST")"
  if [ -z "$SKILL_DIR" ]; then
    echo "  unknown host: $HOST (expected: claude, codex, opencode, windsurf)" >&2
    continue
  fi
  link_skill "$PROJECT/$SKILL_DIR"
done

echo ""
echo "Run /lcw init in the project to create the wiki."
