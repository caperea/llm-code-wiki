#!/usr/bin/env bash
# LCW setup — register skill with a project
set -e

LCW_DIR="$(cd "$(dirname "$0")" && pwd -P)"
SKILL_SRC="$LCW_DIR/skills/lcw"

# ─── Parse flags ──────────────────────────────────────────────

PROJECT=""
while [ $# -gt 0 ]; do
  case "$1" in
    --project)   PROJECT="$2"; shift 2 ;;
    --project=*) PROJECT="${1#--project=}"; shift ;;
    -h|--help)
      cat <<'EOF'
Usage: ./setup --project <path>

Register LCW skill with a project by creating a symlink at
<project>/.claude/skills/lcw -> ~/.lcw/skills/lcw

Examples:
  ./setup --project .              # current directory
  ./setup --project ~/work/my-wiki # specific project

Without --project, prints this help.
EOF
      exit 0
      ;;
    *)  shift ;;
  esac
done

if [ -z "$PROJECT" ]; then
  echo "Usage: ./setup --project <path>"
  echo "Run ./setup --help for details."
  exit 1
fi

# ─── Resolve project path ────────────────────────────────────

PROJECT="$(cd "$PROJECT" && pwd -P)"
DEST="$PROJECT/.claude/skills"

mkdir -p "$DEST"

# ─── Create symlink ──────────────────────────────────────────

if [ -L "$DEST/lcw" ]; then
  echo "Updating existing symlink..."
  rm "$DEST/lcw"
elif [ -e "$DEST/lcw" ]; then
  echo "Error: $DEST/lcw exists and is not a symlink. Remove it first." >&2
  exit 1
fi

ln -s "$SKILL_SRC" "$DEST/lcw"
echo "lcw ready: $DEST/lcw -> $SKILL_SRC"
echo ""
echo "Run /lcw init in the project to create the wiki."
