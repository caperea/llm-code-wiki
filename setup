#!/usr/bin/env bash
# LCW setup — register commands with Claude Code, Codex, or OpenCode
set -e

LCW_DIR="$(cd "$(dirname "$0")" && pwd -P)"

# ─── Parse flags ──────────────────────────────────────────────

HOSTS=""
while [ $# -gt 0 ]; do
  case "$1" in
    --host)   HOSTS="$HOSTS $2"; shift 2 ;;
    --host=*) HOSTS="$HOSTS ${1#--host=}"; shift ;;
    *)        shift ;;
  esac
done

# ─── Auto-detect: install for all found tools ────────────────

if [ -z "$HOSTS" ]; then
  command -v claude   >/dev/null 2>&1 && HOSTS="$HOSTS claude"
  command -v codex    >/dev/null 2>&1 && HOSTS="$HOSTS codex"
  command -v opencode >/dev/null 2>&1 && HOSTS="$HOSTS opencode"
  [ -z "$HOSTS" ] && HOSTS="claude"
fi

# ─── Link commands ────────────────────────────────────────────

link_commands() {
  local dest="$1"
  mkdir -p "$dest"
  for f in "$LCW_DIR/commands"/lcw-*.md; do
    ln -sf "$f" "$dest/$(basename "$f")"
  done
}

for HOST in $HOSTS; do
  case "$HOST" in
    claude)
      link_commands "$HOME/.claude/commands"
      echo "lcw ready (claude).  commands: ~/.claude/commands/lcw-*.md"
      ;;
    codex)
      link_commands "$HOME/.codex/commands"
      echo "lcw ready (codex).   commands: ~/.codex/commands/lcw-*.md"
      ;;
    opencode)
      link_commands "$HOME/.opencode/commands"
      mkdir -p "$HOME/.opencode/agents"
      ln -sf "$LCW_DIR/agents/wiki.md" "$HOME/.opencode/agents/wiki.md"
      echo "lcw ready (opencode). commands: ~/.opencode/commands/lcw-*.md"
      ;;
    *)
      echo "Unknown host: $HOST (expected: claude, codex, opencode)" >&2
      exit 1
      ;;
  esac
done

echo ""
echo "Run /lcw-init in your project to create the wiki."
